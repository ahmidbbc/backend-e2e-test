# Google OAuth2 — obtain from https://console.cloud.google.com/
# 1. Create a project, enable "Google Identity" (People API) or OAuth consent screen
# 2. APIs & Services > Credentials > Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session secret — any long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# JWT signing secret — any long random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# Postgres connection string
DATABASE_URL=postgres://localhost:5432/backend_e2e_test

PORT=3000
